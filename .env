# ============================================
# External API Configuration
# ============================================
# External authentication API URL (for login/signup)
# Use either FOREX_URL or EXTERNAL_API_URL
FOREX_URL=https://api.app.hustle.ai/
# EXTERNAL_API_URL=

# ============================================
# Bland.ai Configuration
# ============================================
# Bland.ai API key for phone call services
BLAND_AI_API_KEY=org_8739cf8ffb6bf6d3647e516ec12f9f05bde00a009f0b5b78015db2d84aa46092cf4e096776ae68b97d9069
# Alternative variable name (some routes use this)
BLAND_API_KEY=org_8739cf8ffb6bf6d3647e516ec12f9f05bde00a009f0b5b78015db2d84aa46092cf4e096776ae68b97d9069

# ============================================
# Stripe Configuration
# ============================================
# Stripe secret key (starts with sk_)
STRIPE_SECRET_KEY=
# Stripe publishable key (starts with pk_)
STRIPE_PUBLISHABLE_KEY=
# Stripe webhook secret (starts with whsec_)
STRIPE_WEBHOOK_SECRET=

# ============================================
# PayPal Configuration
# ============================================
# PayPal Client ID
PAYPAL_CLIENT_ID=
# PayPal Client Secret
PAYPAL_CLIENT_SECRET=
# PayPal Environment: 'sandbox' or 'live' or 'production'
PAYPAL_ENV=sandbox
# PayPal Webhook ID
PAYPAL_WEBHOOK_ID=
# PayPal Client ID (public - for frontend)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# ============================================
# Twilio Configuration
# ============================================
# Twilio Account SID
TWILIO_ACCOUNT_SID=ACb3952ad5a16f45bcd8fa2e2f5c0ebd53
# Twilio Auth Token
TWILIO_AUTH_TOKEN=e0a99ef818558db2c07a93eac21f26ce
